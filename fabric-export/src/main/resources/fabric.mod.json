{
  "schemaVersion": 1,
  "id": "shadow-client",
  "version": "${version}",
  "name": "Shadow Client",
  "description": "A modern Minecraft hack client with a sleek UI.",
  "authors": [
    "YourName"
  ],
  "contact": {
    "homepage": "https://example.com/",
    "sources": "https://github.com/yourname/shadow-client"
  },
  "license": "MIT",
  "icon": "assets/shadow/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "com.twojmod.shadow.Shadow"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.twojmod.shadow.ShadowClient"
      }
    ]
  },
  "mixins": [
    "shadow.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.5",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-language-kotlin": ">=1.12.1+kotlin.2.0.20",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
